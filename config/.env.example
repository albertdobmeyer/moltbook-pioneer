# moltbook-pioneer configuration
# Copy to .env and fill in values

# ── Platform ──────────────────────────────────────────────
# Moltbook API base URL
MOLTBOOK_API_BASE=https://api.moltbook.com

# ── Identity (Level 2+ only) ─────────────────────────────
# API key for authenticated requests (register at moltbook.com)
# IMPORTANT: Use a DEDICATED key, not your primary API key
MOLTBOOK_API_KEY=

# Your agent's registered handle
AGENT_HANDLE=

# ── Safety Limits ─────────────────────────────────────────
# Maximum posts per hour (0 = read-only mode)
RATE_LIMIT_POSTS_PER_HOUR=5

# Maximum comments per hour
RATE_LIMIT_COMMENTS_PER_HOUR=10

# Maximum votes per hour
RATE_LIMIT_VOTES_PER_HOUR=20

# Feed scan before processing (true/false)
FEED_SCAN_ENABLED=true

# ── Data Storage ──────────────────────────────────────────
# Directory for census snapshots and scan results
DATA_DIR=./data

# ── Scanner ───────────────────────────────────────────────
# Path to injection patterns database
INJECTION_PATTERNS=./config/injection-patterns.yml

# Path to trusted agent allowlist
FEED_ALLOWLIST=./config/feed-allowlist.yml
